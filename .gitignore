# ───── Dependencies ─────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ───── Build output ─────
/dist/
/build/
*.tsbuildinfo

# ───── ElizaOS ─────
/.eliza/
memory.*

# ───── Next.js (frontend/) ─────
frontend/.next/
frontend/out/
frontend/next-env.d.ts

# ───── Environment ─────
.env
.env.local
.env.*.local
# Keep .env.example committed for onboarding
!.env.example
!frontend/.env.example

# ───── Lock files (regenerated on install) ─────
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
bun.lock

# ───── OS / IDE ─────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ───── Debug logs ─────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ───── Testing ─────
/coverage/
.nyc_output/

# ───── Misc ─────
.vercel/
.mastra/
*.pem
*.tmp
*.temp
.cache/
