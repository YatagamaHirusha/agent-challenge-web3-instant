# =============================================================
# Nosana x ElizaOS Agent Challenge — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# web3journalist plugin (this repo) reads at runtime:
#   HELIUS_API_KEY — helisProvider (Helius REST)
#   WEB3INSTANT_API_URL, WEB3INSTANT_API_SECRET — publishArticle (must match Web3Instant .env.local)
#   WEB3JOURNALIST_INTERVAL_MINUTES — minutes between auto RSS→article→publish (default: 5). Change in .env for production e.g. 180 (3h).
#   WEB3JOURNALIST_FIRST_RUN_DELAY_SEC — seconds after agent start before first run (default: 30)
#   SOL_PRICE_USD — optional override in character settings / runtime
# Not used by src/plugins/web3journalist today: SUPABASE_*, SOLANA_RPC_URL (safe to leave or use later).
# ElizaOS / Twitter / Telegram keys are consumed by the agent runtime or other plugins, not listed in src grep.

# -------------------------------------------------------------
# LLM Configuration — Qwen3.5-27B via Nosana Inference Endpoint
# -------------------------------------------------------------
# Nosana provides a hosted Qwen3.5-27B endpoint for the challenge.
# Use the URL below for development. No GPU required locally.

OPENAI_API_KEY=nosana
OPENAI_API_URL=https://5i8frj7ann99bbw9gzpprvzj2esugg39hxbb4unypskq.node.k8s.prd.nos.ci/v1

# Model name as served by the Nosana endpoint
MODEL_NAME=Qwen3.5-9B-FP8

# -------------------------------------------------------------
# Embedding Configuration — via Nosana Inference Endpoint
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Option B: Local development with Ollama (optional)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen3.5:27b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b

# -------------------------------------------------------------
# ElizaOS / Ollama (ChainPulse — Docker or alternate local stack)
# -------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# MODEL_NAME=hf.co/Qwen/Qwen2.5-7B-Instruct-GGUF

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Database (SQLite — sufficient for development)
# -------------------------------------------------------------
# Default: ./data/db.sqlite (created automatically)
# For production, consider a persistent storage solution.
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Helius (Solana RPC + Webhooks) — free at helius.dev
# -------------------------------------------------------------
HELIUS_API_KEY=a613863b-b1cf-4462-8028-73718d20a5fd
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=a613863b-b1cf-4462-8028-73718d20a5fd

# -------------------------------------------------------------
# Twitter/X API v2 — developer.twitter.com
# -------------------------------------------------------------
# Required when @elizaos/plugin-twitter is in characters/agent.character.json (agent will not start without all four).
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_ENABLE_POST=true
TWITTER_DRY_RUN=false
TWITTER_RETRY_LIMIT=5
TWITTER_ENABLE_REPLIES=false
TWITTER_ENABLE_ACTIONS=false

# -------------------------------------------------------------
# Telegram Bot — @BotFather on Telegram
# -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Channel / group / supergroup ID to receive each published article (e.g. -1001234567890). Bot must be admin in the channel.
TELEGRAM_CHANNEL_ID=

# -------------------------------------------------------------
# Web3Instant publishing (ChainPulse)
# -------------------------------------------------------------
# Production: https://web3instant.com
# Local dev: run Web3Instant Next.js on 3001: cd Web3Instant/app && npx next dev -p 3001
# Keep ElizaOS on 3000 (default). If 3000 is taken, Eliza picks another port — avoid clashing with 3001.
WEB3INSTANT_API_URL=http://localhost:3001
WEB3INSTANT_API_SECRET=your_internal_secret_here

# Automated scheduler (src/plugins/web3journalist/services/scheduler.ts)
# WEB3JOURNALIST_INTERVAL_MINUTES=5
# WEB3JOURNALIST_FIRST_RUN_DELAY_SEC=30

# -------------------------------------------------------------
# Supabase (optional — agent publishes via WEB3INSTANT_API_*; no Supabase client in plugin yet)
# -------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -------------------------------------------------------------
# Optional: Other social integrations
# -------------------------------------------------------------
# Discord bot — https://discord.com/developers/applications
# DISCORD_API_TOKEN=


