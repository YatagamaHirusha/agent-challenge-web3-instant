FROM node:20-slim

# Install OpenSSL (required for some Prisma/Supabase clients) and other libs for Sharp if needed
RUN apt-get update -y && apt-get install -y openssl ca-certificates

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (including dev dependencies for tsx)
RUN npm ci

# Copy the rest of the application code
COPY . .

# Set environment to production
ENV NODE_ENV=production

# Run the bot script directly
CMD ["npm", "run", "bot"]
